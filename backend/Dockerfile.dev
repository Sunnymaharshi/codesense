FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

WORKDIR /app

ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PYTHON_DOWNLOADS=never \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    VIRTUAL_ENV=/venv \
    PATH="/venv/bin:$PATH" \
    PYTHONPATH="/app"

COPY pyproject.toml uv.lock ./

# Explicitly create venv at /venv and sync all deps into it
RUN uv venv /venv && \
    UV_PROJECT_ENVIRONMENT=/venv uv sync --frozen --no-install-project --dev

# Verify binaries landed correctly — fast fail at build time
RUN /venv/bin/uvicorn --version && /venv/bin/celery --version

# Pre-download the fastembed model so the first container start doesn't wait for 130MB.
# The named volume at /root/.cache/fastembed is initialised from this layer on first `make dev`.
RUN /venv/bin/python -c "from fastembed import TextEmbedding; TextEmbedding('BAAI/bge-small-en-v1.5')"

# No COPY . . — source is volume-mounted for hot reload
EXPOSE 8000