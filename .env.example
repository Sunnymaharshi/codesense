# ── Required ─────────────────────────────────────────────────────────────────

# GitHub personal access token — public_repo scope only
# Create at: https://github.com/settings/tokens/new?scopes=public_repo
GITHUB_TOKEN=

# Groq API key — free tier gives 14,400 req/day, no credit card needed
# Create at: https://console.groq.com/keys
GROQ_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────

ENVIRONMENT=development

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# No trailing slash — WebSocket origin check is exact match
CORS_ORIGINS=http://localhost:5173

# ── Database (Docker — matches docker-compose.yml) ────────────────────────────

DATABASE_URL=postgresql+asyncpg://codesense:codesense@postgres:5432/codesense

# ── Redis (Docker) ────────────────────────────────────────────────────────────

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── LangSmith tracing (optional) ─────────────────────────────────────────────

LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=codesense

# ── Sentry (optional, production only) ───────────────────────────────────────

SENTRY_DSN_BACKEND=
